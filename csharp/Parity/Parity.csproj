<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>HollowPines.Parity</RootNamespace>
  </PropertyGroup>

  <!-- Compile the engine-agnostic sim sources directly (same files Unity will import). -->
  <ItemGroup>
    <Compile Include="../HollowPines.Sim/*.cs" />
  </ItemGroup>

  <!-- Ship the golden fixture (generated from the TypeScript sim) next to the binary. -->
  <ItemGroup>
    <None Include="../parity/golden.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
